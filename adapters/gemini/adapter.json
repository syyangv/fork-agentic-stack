{
  "name": "gemini",
  "description": "Gemini CLI — GEMINI.md + .gemini/settings.json hooks + .gemini/skills mirror.",
  "files": [
    {
      "src": "GEMINI.md",
      "dst": "GEMINI.md",
      "merge_policy": "merge_or_alert"
    },
    {
      "src": "settings.json",
      "dst": ".gemini/settings.json",
      "merge_policy": "merge_or_alert"
    }
  ],
  "skills_link": {
    "target": ".agent/skills",
    "dst": ".gemini/skills",
    "fallback": "copy_with_merge"
  }
}
