{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.memory.context.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "intent", "project_id", "routing", "sections", "warnings", "health", "token_estimate"],
  "properties": {
    "schema": {"const": "agentic.memory.context.v1"},
    "intent": {"type": "string", "minLength": 1, "maxLength": 2000},
    "project_id": {"type": "string", "pattern": "[0-9a-f]{16}"},
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["governance", "behavioral", "evidence"],
      "properties": {
        "governance": {"type": "boolean"},
        "behavioral": {"type": "boolean"},
        "evidence": {"type": "boolean"}
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lane", "items"],
        "properties": {
          "lane": {"type": "string", "enum": ["governance", "behavioral", "evidence"]},
          "items": {"type": "array", "items": {"type": "object"}}
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string", "maxLength": 2000}},
    "health": {"type": "object"},
    "token_estimate": {"type": "integer", "minimum": 0, "maximum": 12000}
  }
}
