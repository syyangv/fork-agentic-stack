{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.memory.evidence-ledger.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "evidence_id", "summary", "provenance", "verification"],
  "properties": {
    "schema": {"type": "string", "const": "agentic.memory.evidence-ledger.v1"},
    "evidence_id": {"type": "string", "pattern": "evi_[0-9a-f]{64}"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "provider", "source_id", "project_id", "repository_revision", "source_hash", "observed_at", "confidence", "freshness", "locator"],
      "properties": {
        "kind": {"type": "string", "enum": ["crg_node", "crg_flow", "test_run"]},
        "provider": {"type": "string", "enum": ["crg", "test-runner"]},
        "source_id": {"type": "string", "pattern": "evi_[0-9a-f]{64}"},
        "project_id": {"type": "string", "pattern": "[0-9a-f]{16}"},
        "repository_revision": {"type": "string", "pattern": "[0-9a-f]{7,64}", "maxLength": 128},
        "source_hash": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"},
        "observed_at": {"type": "string", "pattern": "[0-9]{4}-[0-9]{2}-[0-9]{2}T[^ ]+(Z|\\+00:00)", "maxLength": 64},
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "freshness": {"type": "string", "const": "fresh"},
        "locator": {"type": "object"}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_reconciled", "files_reconciled", "symbols_reconciled", "executed_test"],
      "properties": {
        "repository_reconciled": {"type": "boolean"},
        "files_reconciled": {"type": "boolean"},
        "symbols_reconciled": {"type": "boolean"},
        "executed_test": {"type": "boolean"}
      }
    }
  }
}
