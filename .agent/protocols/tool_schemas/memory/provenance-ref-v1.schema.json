{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentic.memory.provenance.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "provider", "source_id", "project_id", "repository_revision", "source_hash", "observed_at", "confidence", "freshness", "locator"],
  "properties": {
    "kind": {"type": "string", "enum": ["lesson", "decision", "episode", "trace", "policy", "world_model", "skill", "crg_node", "crg_flow", "test_run"]},
    "provider": {"type": "string", "enum": ["agentic-stack", "memos-local", "crg", "test-runner"]},
    "source_id": {"type": "string", "minLength": 1, "maxLength": 512},
    "project_id": {"type": "string", "pattern": "[0-9a-f]{16}"},
    "repository_revision": {"type": ["string", "null"], "pattern": "[0-9a-f]{7,64}", "maxLength": 128},
    "source_hash": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"},
    "observed_at": {"type": "string", "pattern": "[0-9]{4}-[0-9]{2}-[0-9]{2}T[^ ]+(Z|\\+00:00)", "maxLength": 64},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "freshness": {"type": "string", "enum": ["fresh", "stale", "unknown"]},
    "locator": {"type": "object"}
  }
}
